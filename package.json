{
  "name": "tavsin",
  "license": "ISC",
  "scripts": {
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "typecheck:sample-sdk": "tsc -p examples/sdk-client/tsconfig.json --noEmit",
    "verify:pretest": "npm run lint && npm --prefix app run lint && npm --prefix app run build && npm run test:anchor:skip-build && npm run typecheck:sample-sdk",
    "test:anchor": "anchor test --validator legacy",
    "test:anchor:skip-build": "anchor test --validator legacy --skip-build",
    "validate:reads": "ts-node --esm scripts/validate-reads.ts"
  },
  "dependencies": {
    "@anchor-lang/core": "^1.0.0",
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/web3.js": "^1.98.4"
  },
  "devDependencies": {
    "@solana/spl-token": "^0.4.14",
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^11.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
