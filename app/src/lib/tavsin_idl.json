            ],
            "type": "i64"
          },
          {
            "name": "period_duration",
            "docs": [
              "Period duration in seconds (default: 86400 = 24 hours)."
            ],
            "type": "i64"
          },
          {
            "name": "bump",
            "docs": [
              "Bump seed."
            ],
            "type": "u8"
          }
        ]
      }
