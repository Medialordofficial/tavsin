# Tavsin Web App — environment variables
#
# All NEXT_PUBLIC_* values are inlined into the client bundle.

# ---- on-chain ----
NEXT_PUBLIC_TAVSIN_PROGRAM_ID=2VzG2545ksX8cUSggRxQ6DUpDdFb1q9vkZwFftvWcbFy
NEXT_PUBLIC_SOLANA_CLUSTER=devnet

# Override the public RPC. STRONGLY RECOMMENDED in production — the default
# api.devnet.solana.com endpoint rate-limits aggressively and will silently
# drop `connection.onLogs` events that power the /live deny feed.
#
# Free tiers that work great: Helius, Triton, QuickNode.
# NEXT_PUBLIC_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# ---- server-only (never bundled) ----
# Server-side RPC (used by /api/* routes). Falls back to NEXT_PUBLIC_SOLANA_RPC_URL.
# TAVSIN_SOLANA_RPC_URL=
# HELIUS_RPC_URL=

# Telegram bot for human-in-the-loop approvals.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=
