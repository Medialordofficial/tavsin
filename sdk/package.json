{
  "name": "@tavsin/sdk",
  "version": "0.1.0",
  "description": "TavSin SDK — policy-enforced smart wallet for AI agents on Solana",
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "keywords": [
    "solana",
    "smart-wallet",
    "ai-agent",
    "policy-engine",
    "tavsin",
    "anchor"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Medialordofficial/tavsin.git",
    "directory": "sdk"
  },
  "homepage": "https://tavsin.xyz",
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4"
  }
}